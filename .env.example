# ── Server ────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=https://your-ngrok-url.ngrok.io   # Public URL for webhooks

# ── Exotel ────────────────────────────────────────────────────────────
EXOTEL_SID=your_account_sid                    # Exotel dashboard se
EXOTEL_API_KEY=your_api_key                    # Exotel dashboard se
EXOTEL_API_TOKEN=your_api_token                # Exotel dashboard se
EXOTEL_CALLER_ID=+918XXXXXXXXX                 # Tumhara ExoPhone number
EXOTEL_SUBDOMAIN=api.exotel.com                # Default rehne do

# ── Meta / Facebook ───────────────────────────────────────────────────
META_VERIFY_TOKEN=propcrm_secret_123
META_APP_SECRET=your_meta_app_secret
META_PAGE_ACCESS_TOKEN=your_page_access_token
